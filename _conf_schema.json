{
    "active_world": {
        "description": "🎯 默认激活世界观",
        "hint": "下拉选择默认主导推荐官所在的世界。用于决定常规句式人称 and 基础表情包来源。",
        "type": "string",
        "options": ["世界1(鸣潮)", "世界2(原神)", "世界3(自定义)", "世界4(自定义)"],
        "default": "世界1(鸣潮)"
    },
    "world1_aliases": {
        "description": "🔍 世界1 触发别名",
        "hint": "发送例如“鸣潮特产”、“索拉里斯特产”，自动强转到世界1抓取食物。可自定义唤醒前缀。格式: [\"鸣潮\", \"索拉里斯\"]",
        "type": "list",
        "items": {"type": "string"},
        "default": ["鸣潮", "索拉里斯"]
    },
    "world2_aliases": {
        "description": "🔍 世界2 触发别名",
        "hint": "发送例如“原神特产”、“提瓦特特产”，自动强转到世界2抓取食物。可自定义唤醒前缀。格式: [\"原神\", \"提瓦特\"]",
        "type": "list",
        "items": {"type": "string"},
        "default": ["原神", "提瓦特"]
    },
    "world3_aliases": {
        "description": "🔍 世界3 触发别名",
        "hint": "自定义世界3的触发别名列表",
        "type": "list",
        "items": {"type": "string"},
        "default": []
    },
    "world4_aliases": {
        "description": "🔍 世界4 触发别名",
        "hint": "自定义世界4的触发别名列表",
        "type": "list",
        "items": {"type": "string"},
        "default": []
    },
    "global_meme_prob": {
        "description": "🎲 常规 Meme 掉落概率 (%)",
        "hint": "普通发饭时，附带发送常规吐槽表情包的概率 (0-100)",
        "type": "int",
        "default": 30
    },
    "chef_meme_prob": {
        "description": "🍳 厨师图鉴触发概率 (%)",
        "hint": "触发带【厨师名】的特制食物时，同步发送该厨师立绘/动图的概率 (0-100)",
        "type": "int",
        "default": 50
    },
    "interception_egg_chance": {
        "description": "⚔️ 拦截乱入夺食概率 (%)",
        "hint": "由于触发防刷屏拦截时，值班干饭人直接乱入夺食并发送抢饭语录的概率 (0-100)",
        "type": "int",
        "default": 50
    },
    "history_limit": {
        "description": "🕰️ 群组防重复记忆长度",
        "hint": "同一个群聊内，最近X次抽取到的食物/饮品绝对不会重复出现。设置为0则关闭此功能。",
        "type": "int",
        "default": 30
    },
    "spam_threshold": {
        "description": "🛑 防刷屏拦截触发次数",
        "hint": "60秒内允许连续触发的最大次数。超过后将发送各推荐官的【无语】打断表情与人设化句式。",
        "type": "int",
        "default": 3
    },
    "enable_ai": {
        "description": "🤖 开启 AI 优先智能拟人回复",
        "hint": "开启后将自动接入当前 AstrBot 所配置的底层人格数据进行现场对白。",
        "type": "bool",
        "default": false
    },
    "ai_probability": {
        "description": "🎲 AI 回复触发概率",
        "hint": "0-100。当上方开启AI回复后，每次抽签有对应概率不走死板模板，而是让大模型现场生成带有情绪的台词。",
        "type": "int",
        "default": 5
    },
    "egg_prob": {
        "description": "🎁 抢饭彩蛋劫持概率",
        "hint": "每次生成推荐时触发抢饭宇宙的概率(0-100)。触发后将截断发图，替换为抢饭叙事。",
        "type": "int",
        "default": 10
    },
    "egg_character": {
        "description": "🎭 默认抢饭首选角色",
        "hint": "对应插件主目录 Still_eating_meme 下的对应子文件夹名（内置千咲、派蒙、达妮娅）。",
        "type": "string",
        "options": ["千咲", "派蒙", "达妮娅"],
        "default": "千咲"
    },
    "repeat_prob": {
        "description": "🔁 摆烂复读概率",
        "hint": "触发推荐官陷入沉思并摆烂复读的概率(0-100)，触发时附带【思考】表情包。",
        "type": "int",
        "default": 10
    },
    "repeat_cooldown": {
        "description": "⏳ 摆烂复读冷却锁定时间 (秒)",
        "hint": "触发一次摆烂复读后，该群聊在指定秒数内将强制进入正常推荐流程，绝不连续摆烂。默认60秒。",
        "type": "int",
        "default": 60
    },
